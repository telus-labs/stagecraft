#!/usr/bin/env node
// devteam — CLI entrypoint for the ai-dev-team orchestrator.
//
// Subcommands (MVP):
//   stage <name> [--feature "..."]    Render the stage prompt(s) for the
//                                     given stage to stdout. For multi-role
//                                     stages, prints one prompt per role
//                                     separated by a divider.
//   hosts                             List installed host adapters.
//   stages                            List known stage names.
//   merge <stage>                     Read pipeline/gates/<stage>.<role>.json
//                                     files and write the merged stage gate.
//   help                              Show this usage.

const path = require("node:path");

const { parseFlags } = require(path.join(__dirname, "..", "core", "cli", "flags"));

// --- All commands dispatched via registry ---
const _helpCmd            = require(path.join(__dirname, "..", "core", "cli", "commands", "help"));
const _stagesCmd          = require(path.join(__dirname, "..", "core", "cli", "commands", "stages"));
const _hostsCmd           = require(path.join(__dirname, "..", "core", "cli", "commands", "hosts"));
const _doctorCmd          = require(path.join(__dirname, "..", "core", "cli", "commands", "doctor"));
const _summaryCmd         = require(path.join(__dirname, "..", "core", "cli", "commands", "summary"));
const _logCmd             = require(path.join(__dirname, "..", "core", "cli", "commands", "log"));
const _stageCmd           = require(path.join(__dirname, "..", "core", "cli", "commands", "stage"));
const _preflightCmd       = require(path.join(__dirname, "..", "core", "cli", "commands", "preflight"));
const _adviseCmd          = require(path.join(__dirname, "..", "core", "cli", "commands", "advise"));
const _nextCmd            = require(path.join(__dirname, "..", "core", "cli", "commands", "next"));
const _runCmd             = require(path.join(__dirname, "..", "core", "cli", "commands", "run"));
const _validateCmd        = require(path.join(__dirname, "..", "core", "cli", "commands", "validate"));
const _verifyChainCmd     = require(path.join(__dirname, "..", "core", "cli", "commands", "verify-chain"));
const _stampChainCmd      = require(path.join(__dirname, "..", "core", "cli", "commands", "stamp-chain"));
const _mergeCmd           = require(path.join(__dirname, "..", "core", "cli", "commands", "merge"));
const _deriveApprovalsCmd = require(path.join(__dirname, "..", "core", "cli", "commands", "derive-approvals"));
const _restartCmd         = require(path.join(__dirname, "..", "core", "cli", "commands", "restart"));
const _rulingCmd          = require(path.join(__dirname, "..", "core", "cli", "commands", "ruling"));
const _fixEscalationCmd   = require(path.join(__dirname, "..", "core", "cli", "commands", "fix-escalation"));

const _initCmd          = require(path.join(__dirname, "..", "core", "cli", "commands", "init"));
const _uiCmd            = require(path.join(__dirname, "..", "core", "cli", "commands", "ui"));
const _memoryCmd        = require(path.join(__dirname, "..", "core", "cli", "commands", "memory"));
const _architectureCmd  = require(path.join(__dirname, "..", "core", "cli", "commands", "architecture"));
const _reproduceCmd     = require(path.join(__dirname, "..", "core", "cli", "commands", "reproduce"));
const _verifyCmd        = require(path.join(__dirname, "..", "core", "cli", "commands", "verify"));
const _replayCmd        = require(path.join(__dirname, "..", "core", "cli", "commands", "replay"));
const _ciCmd            = require(path.join(__dirname, "..", "core", "cli", "commands", "ci"));
const _specCmd          = require(path.join(__dirname, "..", "core", "cli", "commands", "spec"));
const _consistencyCmd   = require(path.join(__dirname, "..", "core", "cli", "commands", "consistency"));
const _assessCmd        = require(path.join(__dirname, "..", "core", "cli", "commands", "assess"));
const _standardsCmd     = require(path.join(__dirname, "..", "core", "cli", "commands", "standards"));
const _hookCmd          = require(path.join(__dirname, "..", "core", "cli", "commands", "hook"));
const _statusCmd        = require(path.join(__dirname, "..", "core", "cli", "commands", "status"));


const _registry = Object.create(null);
for (const cmd of [
  _helpCmd, _stagesCmd, _hostsCmd, _doctorCmd, _summaryCmd, _logCmd,
  _stageCmd, _preflightCmd, _adviseCmd, _nextCmd, _runCmd,
  _validateCmd, _verifyChainCmd, _stampChainCmd, _mergeCmd,
  _deriveApprovalsCmd, _restartCmd, _rulingCmd, _fixEscalationCmd,
  _initCmd, _uiCmd, _memoryCmd, _architectureCmd, _reproduceCmd,
  _verifyCmd, _replayCmd, _ciCmd, _specCmd, _consistencyCmd,
  _assessCmd, _standardsCmd, _hookCmd, _statusCmd,
]) {
  _registry[cmd.name] = cmd;
}

function main() {
  const [, , command, ...rest] = process.argv;

  // Help aliases bypass the registry lookup (no flag parsing needed).
  if (command === "-h" || command === "--help" || command === undefined) {
    return _registry.help.run([], {});
  }

  if (_registry[command]) {
    const cmd = _registry[command];
    const { positional, flags } = parseFlags(rest, cmd.flags);
    return cmd.run(positional, flags);
  }

  console.error(`Unknown command: ${command}`);
  _registry.help.run([], {});
  process.exit(2);
}

try {
  main();
} catch (err) {
  console.error(`devteam: ${err.message}`);
  process.exit(1);
}
