#!/usr/bin/env node
// devteam — CLI entrypoint for the stagecraft orchestrator.
//
// Subcommands (MVP):
//   stage <name> [--feature "..."]    Render the stage prompt(s) for the
//                                     given stage to stdout. For multi-role
//                                     stages, prints one prompt per role
//                                     separated by a divider.
//   hosts                             List installed host adapters.
//   stages                            List known stage names.
//   merge <stage>                     Read pipeline/gates/<stage>.<role>.json
//                                     files and write the merged stage gate.
//   help                              Show this usage.

const path = require("node:path");

const { parseFlags } = require(path.join(__dirname, "..", "core", "cli", "flags"));

// Keep command discovery cheap: map command names to module names, then require
// only the selected command after argv tells us what the user requested.
const COMMAND_MODULES = Object.freeze({
  help: "help",
  stages: "stages",
  hosts: "hosts",
  doctor: "doctor",
  summary: "summary",
  log: "log",
  stage: "stage",
  preflight: "preflight",
  advise: "advise",
  next: "next",
  run: "run",
  commit: "commit",
  compact: "compact",
  validate: "validate",
  "verify-chain": "verify-chain",
  "stamp-chain": "stamp-chain",
  merge: "merge",
  "derive-approvals": "derive-approvals",
  restart: "restart",
  ruling: "ruling",
  "fix-escalation": "fix-escalation",
  init: "init",
  ui: "ui",
  memory: "memory",
  architecture: "architecture",
  reproduce: "reproduce",
  verify: "verify",
  replay: "replay",
  ci: "ci",
  spec: "spec",
  consistency: "consistency",
  assess: "assess",
  standards: "standards",
  hook: "hook",
  status: "status",
  evidence: "evidence",
  report: "report",
  prototype: "prototype",
});

const commandCache = Object.create(null);

function loadCommand(commandName) {
  const moduleName = COMMAND_MODULES[commandName];
  if (!moduleName) return null;
  if (!commandCache[commandName]) {
    commandCache[commandName] = require(path.join(
      __dirname, "..", "core", "cli", "commands", moduleName,
    ));
  }
  return commandCache[commandName];
}

function main() {
  const [, , command, ...rest] = process.argv;

  // Help aliases bypass the registry lookup (no flag parsing needed).
  if (command === "-h" || command === "--help" || command === undefined) {
    return loadCommand("help").run([], {});
  }

  const cmd = loadCommand(command);
  if (cmd) {
    const { positional, flags } = parseFlags(rest, cmd.flags);
    return cmd.run(positional, flags);
  }

  console.error(`Unknown command: ${command}`);
  loadCommand("help").run([], {});
  process.exit(2);
}

try {
  main();
} catch (err) {
  console.error(`devteam: ${err.message}`);
  process.exit(1);
}
