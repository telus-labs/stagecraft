{
  "name": "codex",
  "displayName": "Codex CLI",
  "version": "1",
  "hooks": false,
  "subagents": false,
  "slashCommands": false,
  "worktrees": true,
  "headless": true,
  "headlessCommand": "codex exec --sandbox workspace-write",
  "goalLoop": true,
  "skillFormat": "markdown",
  "rolePromptsDir": ".codex/prompts/roles",
  "skillsDir": ".codex/skills",
  "enforces": {
    "allowed_writes": "post-hoc-audit",
    "stoplist": "prompt-only",
    "shell": true,
    "network": true,
    "tool_budget": "prompt-only"
  }
}
