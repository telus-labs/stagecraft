{
  "name": "openai-compat",
  "displayName": "OpenAI-compatible API (OpenRouter, DeepSeek, Moonshot, etc.)",
  "version": "1",
  "hooks": false,
  "subagents": false,
  "slashCommands": false,
  "worktrees": false,
  "headless": true,
  "httpNative": true,
  "goalLoop": false,
  "skillFormat": "markdown",
  "rolePromptsDir": ".openai-compat/prompts/roles",
  "skillsDir": ".openai-compat/skills",
  "enforces": {
    "allowed_writes": "post-hoc-audit",
    "stoplist": "prompt-only",
    "shell": false,
    "network": true,
    "tool_budget": "prompt-only"
  }
}
