{
  "name": "gemini-cli",
  "displayName": "Gemini CLI",
  "version": "1",
  "hooks": false,
  "subagents": false,
  "slashCommands": false,
  "worktrees": true,
  "headless": true,
  "headlessCommand": "gemini",
  "skillFormat": "markdown",
  "rolePromptsDir": ".gemini/prompts/roles",
  "skillsDir": ".gemini/skills",
  "enforces": {
    "allowed_writes": "prompt-only",
    "stoplist": "prompt-only"
  }
}
